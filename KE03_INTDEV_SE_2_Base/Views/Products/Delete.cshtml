@model DataAccessLayer.Models.Product

@{
    ViewData["Title"] = "Delete";
}

<div class="h1">@Html.DisplayFor(p => p.Name) Verwijderen</div>

<div class="fs-3">Weet je het zeker?</div>
<div>
    <hr />
    <dl class="row fs-5">
        <dt class = "col-sm-2">
            Titel
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            Barcode
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ProductCode)
        </dd>
        <dt class = "col-sm-2">
            Beschrijving
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            Prijs
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            Voorraad
        </dt>
        <dd class = "col-sm-10">
            @if (Model.Stock == null)
            {
                <text>Geen voorraad ingevoerd</text>
            }
            @Html.DisplayFor(model => model.Stock)
            
        </dd>
        <dt class = "col-sm-2">
            Categorie
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Category.Name)
        </dd>
    </dl>
    <div class="row mt-3">
        <div class="col">
        <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />

				<a asp-action="Index" class="btn btn-secondary">Terug naar lijst</a>
			</form>
        </div>
    </div>
</div>
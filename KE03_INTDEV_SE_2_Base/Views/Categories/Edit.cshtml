@model DataAccessLayer.Models.Category

@{
    ViewData["Title"] = "Categorie bewerken";
}

<div class="h1 mb-3">@Html.DisplayFor(p => p.Name) Bewerken</div>
<hr />

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label asp-for="Name" class="control-label">Naam</label>
                <input asp-for="Name" class="form-control" placeholder="Naam..." />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label">Beschrijving</label>
                <textarea asp-for="Description" class="form-control" rows="6" placeholder="Beschrijving..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col">
            <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
            <input type="submit" value="Opslaan" class="btn btn-primary ml-2" />
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

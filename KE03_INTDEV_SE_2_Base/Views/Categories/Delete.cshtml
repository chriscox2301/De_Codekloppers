@model DataAccessLayer.Models.Category

@{
    ViewData["Title"] = "Delete";
}

<div class="h1">@Html.DisplayFor(p => p.Name) Verwijderen</div>

<div class="fs-3">Weet je het zeker?</div>
<div>
    <hr />
    <dl class="row fs-5">
        <dt class = "col-sm-2">
            Naam
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            Beschrijving
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">
            Aantal producten
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Products.Count)
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <div class="form-group">
            <label>Vul de categorienaam ter bevestiging in:</label>
            <input type="text" name="name" class="form-control" style="max-width: 400px;" placeholder="@Html.DisplayNameFor(model => model.Name)" />
            <span class="text-danger">
                @Html.ValidationMessage("name")
            </span>
        </div>

        <div class="row mt-3">
            <div class="col">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
                <input type="submit" value="Delete" class="btn btn-danger" />
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
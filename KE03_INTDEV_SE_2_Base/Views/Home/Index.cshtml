@{
    ViewData["Title"] = "Home Page";
}
<div class="HomeContainer">
    <div class="row">
        <div class="col">
            <div class="card border-2">
                <a class="btn text-dark" asp-area="" asp-controller="Orders" asp-action="Index">Orders</a>
            </div>
        </div>
        <div class="col">
            <div class="card border-2">
                <a class="btn text-dark" asp-area="" asp-controller="Customers" asp-action="Index">Customers</a>
            </div>
        </div>
        <div class="col">
            <div class="card border-2">
                <a class="btn text-dark" asp-area="" asp-controller="Products" asp-action="Index">Products</a>
            </div>
        </div>
        <div class="col">
            <div class="card border-2">
                <a class="btn text-dark" asp-area="" asp-controller="Categories" asp-action="Index">Categorieën</a>
            </div>
        </div>
    </div>

    <div>
        <h5>Producten met lage voorraad:</h5>
        <table class="table table-striped table-hover">
            <tr>
                <th>Code</th>
                <th>Naam</th>
                <th>Voorraad</th>
            </tr>
            @if(Model != null && Model.Count != 0)
            {
                @foreach(var product in Model)
                {
                    <tr>    
                        <td>@product.ProductCode</td>
                        <td>@product.Name</td>
                        <td>@product.Stock</td>
                    </tr>
                }
            }
            else
            {
                <tr>Geen producten laag op voorraad</tr>
            }
        </table>
    </div>
</div>
@model DataAccessLayer.Models.Customer

@{
    ViewData["Title"] = "Delete";
}

<div class="h1">@Html.DisplayFor(p => p.Name) Verwijderen</div>

<div class="fs-3">Weet je het zeker?</div>
<div>
    <hr />
    <dl class="row fs-5">
        <dt class = "col-sm-2">
            Naam
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            Adres
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Address)
        </dd>
        <dt class = "col-sm-2">
            Actief
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Active)
        </dd>
    </dl>
    <div class="row mt-3">
        <div class="col">
        <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />

                <a asp-action="Index" class="btn btn-secondary">Terug naar lijst</a>
            </form>
        </div>
    </div>
</div>

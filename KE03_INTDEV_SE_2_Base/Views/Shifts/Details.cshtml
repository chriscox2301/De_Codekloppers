@model DataAccessLayer.ViewModel.ShiftOrderViewModel

@{
    ViewData["Title"] = "Shift Details";
}

<div class="h1 mb-3">Shift #@Html.DisplayFor(s => s.Shift.Id) Details</div>
<hr />

<div class="productDetails">
    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label class="control-label">Datum</label>
                <div class="form-control border-1 border-secondary">
                    @Html.DisplayFor(s => s.Shift.Date)
                </div>
            </div>
            <div class="form-group">
                <label class="control-label">Bus #</label>
                <div class="form-control border-1 border-secondary">
                    @Html.DisplayFor(s => s.Shift.VehicleId)
                </div>
            </div>
            <div class="form-group">
                <label class="control-label">Bezorger</label>
                <div class="form-control border-1 border-secondary">
                    @Html.DisplayFor(s => s.Shift.Courier.Name)
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <h5>Orders</h5>
            <table id="orderTable" class="table">
                <thead class="bg-secondary text-white">
                    <tr>
                        <th>
                            <input type="checkbox" class="form-check-input" id="selectAll" />
                        </th>
                        <th>
                            Order#
                        </th>
                        <th>
                            Order Datum
                        </th>
                        <th>
                            Klant
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Orders)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" class="form-check-input row-checkbox" />
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Id )
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.OrderDate)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Customer.Name)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model?.Shift.Id">Bewerken</a>
            <a class="btn btn-secondary" asp-action="Index">Terug naar lijst</a>
        </div>
    </div>
</div>

<script src="~/js/site.js"></script>

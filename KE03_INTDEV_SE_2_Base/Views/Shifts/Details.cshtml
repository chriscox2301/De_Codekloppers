@model DataAccessLayer.ViewModel.ShiftOrderViewModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Shift</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Shift.Date)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Shift.Date)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Shift.VehicleId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Shift.VehicleId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Shift.Courier)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Shift.Courier.Name)
        </dd>
    </dl>

    <table id="orderTable" class="table">
        <thead class="bg-secondary text-white">
            <tr>
                <th>
                    <input type="checkbox" class="form-check-input" id="selectAll" />
                </th>
                <th>
                    Order#
                </th>
                <th>
                    Order Datum
                </th>
                <th>
                    Klant
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Orders)
            {
                <tr>
                    <td>
                        #@Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.OrderDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Customer.Name)
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Shift.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

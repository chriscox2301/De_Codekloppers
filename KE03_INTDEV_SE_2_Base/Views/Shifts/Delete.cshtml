@model DataAccessLayer.Models.Shift

@{
    ViewData["Title"] = "Delete";
}

<div class="h1">Shift #@Html.DisplayFor(model => model.Id) Verwijderen</div>

<div class="fs-3">Weet je het zeker?</div>
<div>
    <hr />
    <dl class="row fs-5">
        <dt class = "col-sm-2">
            Datum
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Date)
        </dd>
        <dt class = "col-sm-2">
            Voertuig ID
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.VehicleId)
        </dd>
        <dt class = "col-sm-2">
            Koerier
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Courier.Name)
        </dd>
    </dl>
    <div class="row mt-3">
        <div class="col">
        <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />

                <a asp-action="Index" class="btn btn-secondary">Terug naar lijst</a>
            </form>
        </div>
    </div>
</div>

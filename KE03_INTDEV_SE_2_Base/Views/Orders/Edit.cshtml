@model DataAccessLayer.ViewModel.OrderViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Order</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="OrderDate" type = "date" class="control-label"></label>
                <input asp-for="OrderDate" class="form-control" />
                <span asp-validation-for="OrderDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Customer</label>
                <select asp-for="CustomerId" class="form-control" asp-items="ViewBag.CustomerId"></select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>

            <select id="productSelect" class="form-control">
                @foreach (var product in ViewBag.Products)
                {
                    <option value="@product.Id">
                        @product.Name (€@product.Price)
                    </option>
                }
            </select>
            <button type="button"
                    id="addProductBtn"
                    class="btn btn-success">
                Toevoegen
            </button>
            <ul id="productList" class="list-group">

                @foreach (var product in ViewBag.Products)
                {
                    if (Model.SelectedProductIds.Contains(product.Id))
                    {
                        <li id="product-@product.Id"
                            class="list-group-item d-flex justify-content-between align-items-center">

                            <span>@product.Name (€@product.Price)</span>

                            <button type="button"
                                    class="btn btn-danger btn-sm remove-product">
                                Verwijder
                            </button>
                        </li>
                    }
                }

            </ul>

            <div id="hiddenProductsContainer">

                @foreach (var productId in Model.SelectedProductIds)
                {
                    <input type="hidden"
                           id="hidden-@productId"
                           name="SelectedProductIds"
                           value="@productId" />
                }

            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>  




@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/order-create.js" asp-append-version="true"></script> 
}

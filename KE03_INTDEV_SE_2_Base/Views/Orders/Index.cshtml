@model IEnumerable<DataAccessLayer.Models.Order>

@{
    ViewData["Title"] = "Index";
    
}
@if (TempData["Create"] != null)
{
    <h2 class="bevestigings-bericht">@TempData["Create"]</h2>
}

<h1>Orders</h1>


<div class="d-flex justify-content-start">
	<div class="d-flex w-25">
		<input type="text" id="searchInput" class="form-control" oninput="filterTable()" placeholder="Zoeken op klant">
	</div>
</div>
<div class="d-flex justify-content-end">
    <div class="btn-group d-flex justify-content-end">
    <a class="btn btn-primary" asp-action="Create">Nieuw Order</a>
	
        <div class="btn-group">
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" >Sorteren</button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">Filter 1</a></li>
                <li><a class="dropdown-item" href="#">Filter 2</a></li>
                <li><a class="dropdown-item" href="#">Filter 3</a></li>
			    </ul>
		</div>
	</div>
</div>
<hr/>
    <table id="orderTable" class="table">
    <thead class="bg-secondary text-white">
        <tr>
            <th>
                <input type="checkbox" class="form-check-input" id="selectAll" />
            </th>
            <th>
                Order @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OrderDate)
            </th>
            <th>
                Customer @Html.DisplayNameFor(model => model.Customer.Name)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>  
            <td>
                <input type="checkbox" class="form-check-input row-checkbox" />
            </td>
            <td>
                #@Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OrderDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Customer.Name)
            </td>
            <td>
                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Details</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

<script src="~/js/site.js"></script>
